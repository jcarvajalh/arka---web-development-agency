---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Proyecto {
  id: number;
  nombre: string;
  imagen: string;
  tecnologias: string[];
  descripcion: string;
  link: string;
}

const proyectos: Proyecto[] = [
  {
    id: 1,
    nombre: 'TechStore - E-commerce',
    imagen: 'https://via.placeholder.com/400x300?text=TechStore',
    tecnologias: ['Astro', 'React', 'Tailwind CSS', 'Stripe'],
    descripcion: 'Plataforma de venta de electrónica con carrito de compras integrado. Incrementó ventas en 250% en los primeros 3 meses.',
    link: 'https://ejemplo.com',
  },
  {
    id: 2,
    nombre: 'DesignStudio - Portfolio',
    imagen: 'https://via.placeholder.com/400x300?text=DesignStudio',
    tecnologias: ['Astro', 'Tailwind CSS', 'Animaciones'],
    descripcion: 'Portfolio interactivo para agencia de diseño. Ganó 5 premios internacionales de diseño web.',
    link: 'https://ejemplo.com',
  },
  {
    id: 3,
    nombre: 'FitLife - App de Fitness',
    imagen: 'https://via.placeholder.com/400x300?text=FitLife',
    tecnologias: ['React', 'Node.js', 'MongoDB', 'Firebase'],
    descripcion: 'Aplicación web completa para seguimiento de entrenamientos. 50k usuarios activos mensuales.',
    link: 'https://ejemplo.com',
  },
  {
    id: 4,
    nombre: 'EcoTravel - Agencia de Viajes',
    imagen: 'https://via.placeholder.com/400x300?text=EcoTravel',
    tecnologias: ['Astro', 'Tailwind CSS', 'Google Maps', 'Booking API'],
    descripcion: 'Sitio web de agencia de viajes ecológicos. Posicionado #1 en Google para palabras clave principales.',
    link: 'https://ejemplo.com',
  },
  {
    id: 5,
    nombre: 'MediConnect - SaaS Healthcare',
    imagen: 'https://via.placeholder.com/400x300?text=MediConnect',
    tecnologias: ['React', 'TypeScript', 'Node.js', 'PostgreSQL'],
    descripcion: 'Plataforma SaaS para gestión de pacientes en clínicas. Utilizada por 200+ centros médicos.',
    link: 'https://ejemplo.com',
  },
  {
    id: 6,
    nombre: 'LocalBusiness - Directorio',
    imagen: 'https://via.placeholder.com/400x300?text=LocalBusiness',
    tecnologias: ['Astro', 'Tailwind CSS', 'Geolocalización'],
    descripcion: 'Directorio de negocios locales con mapas y filtros avanzados. 100k búsquedas mensuales.',
    link: 'https://ejemplo.com',
  },
];
---

<BaseLayout title="Nuestros Proyectos - ARKA" description="Proyectos exitosos de agencia de desarrollo web">
  <div class="pt-32 pb-20 bg-gradient-to-br from-blue-50 to-indigo-100">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">Nuestros Proyectos Exitosos</h1>
      <p class="text-xl text-gray-700">
        Casos de éxito que demuestran nuestra experiencia y compromiso con la excelencia.
      </p>
    </div>
  </div>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {proyectos.map((proyecto) => (
          <a 
            href={proyecto.link}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-xl transition group"
          >
            <!-- Imagen -->
            <div class="aspect-video overflow-hidden bg-gray-200">
              <img 
                src={proyecto.imagen} 
                alt={proyecto.nombre}
                class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
              />
            </div>

            <!-- Contenido -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition">
                {proyecto.nombre}
              </h3>

              <!-- Descripción -->
              <p class="text-gray-700 mb-4 text-sm leading-relaxed">
                {proyecto.descripcion}
              </p>

              <!-- Tecnologías -->
              <div class="flex flex-wrap gap-2">
                {proyecto.tecnologias.map((tech) => (
                  <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1 rounded-full">
                    {tech}
                  </span>
                ))}
              </div>

              <!-- Link -->
              <div class="mt-4 pt-4 border-t border-gray-200">
                <span class="text-blue-600 font-semibold text-sm group-hover:text-blue-700 transition">
                  Ver Proyecto →
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-br from-blue-600 to-indigo-700">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold text-white mb-6">¿Tu proyecto podría estar aquí?</h2>
      <p class="text-xl text-blue-100 mb-8">
        Contáctanos para empezar tu próximo proyecto exitoso.
      </p>
      <a 
        href="https://cal.com/arkaagency/reunion-acercamiento" 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold hover:bg-blue-50 transition text-lg"
      >
        Comienza Tu Proyecto
      </a>
    </div>
  </section>
</BaseLayout>
