---
const links = [
  { label: "Servicios", href: "#servicios" },
  { label: "Proyectos", href: "#proyectos" },
  { label: "Precios", href: "#precios" },
];
---

<header
  class="fixed top-5 left-1/2 -translate-x-1/2 z-50 w-[min(780px,calc(100%-32px))]"
  role="banner"
>
  <nav
    class="nav-bar flex items-center justify-center gap-2 px-[14px] py-[10px]"
    aria-label="Navegación principal"
  >
    <a
      href="#"
      class="shrink-0 flex items-center mr-1"
      aria-label="Ir al inicio"
    >
      <img
        src="/arka-agencia-web-cali.png"
        alt="ARKA Logo"
        class="w-8 h-8 object-contain"
        width="35"
        height="35"
      />
    </a>
    <ul
      class="flex items-center gap-1 list-none m-0 p-0 flex-1 justify-center max-sm:hidden"
      role="list"
    >
      {
        links.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="nav-link inline-block px-3.5 py-[7px]"
              data-navlink
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="https://cal.com/arkaagency/reunion-acercamiento"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta shrink-0 px-3 py-1.5 max-[400px]:hidden max-sm:px-[10px] max-sm:py-[5px]"
      aria-label="Cotiza tu proyecto"
    >
      Cotiza tu proyecto
    </a>

    <button
      class="burger group hidden max-sm:flex flex-col justify-center gap-[5px] p-1.5 ml-auto"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span
        class="burger-line block w-[22px] h-[2px] group-aria-expanded:translate-y-[7px] group-aria-expanded:rotate-45"
      ></span>
      <span
        class="burger-line block w-[22px] h-[2px] group-aria-expanded:opacity-0"
      ></span>
      <span
        class="burger-line block w-[22px] h-[2px] group-aria-expanded:-translate-y-[7px] group-aria-expanded:-rotate-45"
      ></span>
    </button>
  </nav>

  <div
    class="mobile-menu-panel mobile-menu hidden flex flex-col gap-1.5 p-4 mt-2"
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Menú móvil"
  >
    <ul role="list">
      {
        links.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="mobile-link block px-3.5 py-2.5"
              data-navlink
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="https://cal.com/arkaagency/reunion-acercamiento"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta block mt-2 w-full px-3 py-1.5"
      >Cotiza tu proyecto</a
    >
  </div>
</header>

<script>
  const burger = document.querySelector(".burger") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLElement;
  const mobileLinks = document.querySelectorAll(".mobile-link");

  burger?.addEventListener("click", () => {
    const isOpen = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!isOpen));
    menu.classList.toggle("hidden", isOpen);
  });

  // Close on link click
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      burger.setAttribute("aria-expanded", "false");
      menu.classList.add("hidden");
    });
  });

  // Active section tracking via IntersectionObserver
  const sections = document.querySelectorAll("section[id]");
  const allLinks = document.querySelectorAll("[data-navlink]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        allLinks.forEach((link) => {
          const href = link.getAttribute("href");
          const isActive = href === `#${entry.target.id}`;
          link.classList.toggle("active", isActive);
        });
      });
    },
    { threshold: 0.5 },
  );

  sections.forEach((section) => observer.observe(section));
</script>
