---
// Hero.astro
---

<!-- ── Sección hero ── -->
<section class="hero-section relative h-screen w-full overflow-hidden">
  <!-- Stack image — centrada absolutamente en el hero -->
  <div
    class="hero-stack absolute z-[1] animate-fade-up"
    style="animation-delay:480ms"
  >
    <img
      src="/ARKA-stack-blanco.png"
      alt="ARKA Stack de tecnologías"
      class="hero-stack-img block w-full h-auto"
      loading="lazy"
    />
  </div>

  <!-- Contenido — borde inferior en el 50% del hero -->
  <div
    class="hero-content absolute left-1/2 z-10 flex w-full max-w-[900px] flex-col items-center text-center animate-fade-up"
  >
    <!-- Eyebrow -->
    <h1 class="hero-eyebrow animate-fade-up">
      Agencia de Desarrollo Web
      <span class="eyebrow-dot">·</span>
      Cali, Colombia
    </h1>

    <!-- Título principal -->
    <h2 class="hero-title animate-fade-up" style="animation-delay:120ms">
      Desarrollo web High - end<br />
      <span> que aumentan sus ventas</span>
    </h2>

    <!-- Descripción -->
    <p class="hero-desc animate-fade-up" style="animation-delay:240ms">
      Webs de alto impacto para compañías tech, e-commerce, clínicas
      odontológicas y de estética.
    </p>

    <!-- CTA — este botón queda exactamente en el 50% del hero -->
    <div class="animate-fade-up" style="animation-delay:360ms">
      <a
        href="https://cal.com/arkaagency/reunion-acercamiento"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-btn"
      >
        Cotiza tu proyecto</a
      >
    </div>
  </div>
</section>

<!-- Shopify Partner — fondo del hero, centrado -->
<div
  class="absolute bottom-7 left-0 z-10 flex w-full items-center justify-center animate-fade-up"
  style="animation-delay:600ms"
>
  <img
    src="/shopify-partner-en-cali-colombia.webp"
    alt="ARKA - Shopify Partner en Cali, Colombia"
    class="hero-shopify-img h-8 w-auto"
    loading="lazy"
  />
</div>
