---
const servicios = [
  {
    id: "diseno",
    titulo: "DISEÑO\nPERSONALIZADO",
    descripcion:
      "Interfaces únicas diseñadas para tu marca. Cada píxel pensado para guiar a tu cliente hacia la acción. Versión desktop y mobile perfectamente adaptadas.",
    imagenSrc: "/servicio-diseño.png",
    imagenAlt: "Diseño personalizado",
    light: false,
  },
  {
    id: "seo",
    titulo: "SEO",
    descripcion:
      "Implementamos SEO en cada página y estructuramos el contenido para alcanzar tasas de conversión ideales.",
    imagenSrc: "/servicio-seo.png",
    imagenAlt: "SEO",
    light: true,
  },
  {
    id: "ia",
    titulo: "IA",
    descripcion:
      "Priorizamos herramientas de inteligencia artificial que automatizan procesos. Sistemas inteligentes para tu negocio.",
    imagenSrc: "/servicios-ai.png",
    imagenAlt: "Inteligencia Artificial",
    light: false,
  },
  {
    id: "tech",
    titulo: "TECNOLOGÍAS\nMODERNAS",
    descripcion:
      "Construimos sitios web de alto rendimiento con tecnologías modernas. Velocidad, seguridad y escalabilidad.",
    imagenSrc: "/servicio-tech.png",
    imagenAlt: "Tecnologías modernas",
    light: true,
  },
];
---

<section id="servicios" class="servicios-section">
  <div class="servicios-inner">

    <!-- Header centrado -->
    <div class="servicios-header">
      <span class="eyebrow">Lo que hacemos</span>
      <h2>Nuestros Servicios</h2>
    </div>

    <!-- Cards -->
    <div class="cards-track" role="list">
      {servicios.map((s, i) => (
        <article
          class={`card${i === 0 ? " is-active" : ""}${s.light ? " card--light" : ""}`}
          role="listitem"
          id={`card-${s.id}`}
          data-index={i}
        >
          <div class="card-inner flex flex-col h-full p-7">

            <div class="card-top mb-4 shrink-0">
              <h3 class="card-title">
                {s.titulo.split("\n").map((line: string, j: number, arr: string[]) => (
                  <span>{line}{j < arr.length - 1 ? <br /> : ""}</span>
                ))}
              </h3>
            </div>

            <div class="card-img-wrap" aria-label={s.imagenAlt}>
              {s.imagenSrc
                ? <img src={s.imagenSrc} alt={s.imagenAlt} class="card-img" loading="lazy" />
                : (
                  <div class="card-placeholder" aria-hidden="true">
                    <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="1" y="1" width="42" height="42" rx="8" stroke="rgba(255,255,255,0.12)" stroke-width="1.5" stroke-dasharray="4 3"/>
                      <path d="M14 30l6-7 4.5 5.5 3.5-4 6 7.5H14z" fill="rgba(255,255,255,0.07)"/>
                      <circle cx="17" cy="17" r="3" fill="rgba(255,255,255,0.1)"/>
                      <text x="50%" y="72%" dominant-baseline="middle" text-anchor="middle" font-size="7" fill="rgba(255,255,255,0.2)" font-family="Inter,sans-serif" letter-spacing="0.06em" font-weight="600">TU IMAGEN</text>
                    </svg>
                  </div>
                )
              }
            </div>

            <div class="card-bottom">
              <p class="card-desc">{s.descripcion}</p>
              <a href="https://cal.com/arkaagency/reunion-acercamiento" target="_blank" rel="noopener noreferrer" class="cta-btn" aria-label={`Cotizar ${s.titulo.replace('\n', ' ')}`}>
                <span>Cotiza tu proyecto</span>
                <span class="cta-icon" aria-hidden="true">›</span>
              </a>
            </div>

          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#servicios .card'));

  function activate(card: HTMLElement) {
    cards.forEach(c => c.classList.remove('is-active'));
    card.classList.add('is-active');
  }

  const isMobile = () => window.matchMedia('(max-width: 640px)').matches;

  // Desktop: mouseenter
  cards.forEach((card) => {
    card.addEventListener('mouseenter', () => {
      if (!isMobile()) {
        activate(card);
      }
    });
  });
</script>