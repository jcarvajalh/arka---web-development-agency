---
// ServicesCarousel.astro

const services = [
  {
    number: "01",
    title: "Diseño Personalizado",
    description:
      "Interfaces únicas diseñadas para tu marca. Cada pixel pensado para guiar a tu visitante hacia la acción. Versión desktop y mobile perfectamente adaptadas.",
    tags: ["UI/UX", "Responsive", "Figma"],
    image: "/images/services/diseno.jpg",
    alt: "Diseño Personalizado",
  },
  {
    number: "02",
    title: "SEO & Conversiones",
    description:
      "No solo creamos sitios bonitos. Implementamos SEO intermedio en cada página y estructuramos el contenido para alcanzar tasas de conversión superiores al 5%.",
    tags: ["SEO Técnico", "CRO", "Analytics"],
    image: "/images/services/seo.jpg",
    alt: "SEO y Conversiones",
  },
  {
    number: "03",
    title: "Automatización con IA",
    description:
      "Integramos herramientas de inteligencia artificial que automatizan procesos: Sistemas inteligentes, generación de contenido y análisis predictivo de comportamiento.",
    tags: ["AI Agents", "Automatización"],
    image: "/images/services/ia.jpg",
    alt: "Automatización con IA",
  },
  {
    number: "04",
    title: "Desarrollo Web Escalable",
    description:
      "Construimos sitios web de alto rendimiento con tecnologías modernas. Velocidad, seguridad y escalabilidad para que tu negocio crezca sin límites técnicos.",
    tags: ["Astro", "Next.js", "Shopify"],
    image: "/images/services/desarrollo.jpg",
    alt: "Desarrollo Web Escalable",
  },
];
---

<section class="services-section">

  <!-- Header -->
  <div class="services-header">
    <p class="section-label">Nuestros Servicios</p>
    <h2 class="section-title">Todo lo que tu negocio necesita para crecer online</h2>
    <p class="section-sub">
      Cuatro pilares estratégicos que convierten tu sitio web en una máquina de ventas.
    </p>
  </div>

  <!-- Carousel -->
  <div class="carousel-outer">
    <div class="carousel-track" id="servicesTrack">
      {
        [...services, ...services].map((service, i) => (
          <div
            class="service-card"
            aria-hidden={i >= services.length ? "true" : undefined}
          >
            <div class="card-image">
              <img
                src={service.image}
                alt={service.alt}
                loading="lazy"
                class="card-img"
              />
              <!-- Placeholder siempre presente debajo; la img lo tapa al cargar -->
              <div class="card-placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="M21 15l-5-5L5 21"/>
                </svg>
                <span>Agrega tu imagen aquí</span>
              </div>
              <div class="card-gradient" />
            </div>

            <div class="card-body">
              <div class="card-number">{service.number}</div>
              <h3 class="card-title">{service.title}</h3>
              <p class="card-desc">{service.description}</p>
              <div class="tags">
                {service.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Controls -->
  <div class="carousel-controls">
    <button class="nav-btn" id="prevBtn" aria-label="Anterior">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button class="nav-btn" id="nextBtn" aria-label="Siguiente">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>
</section>

<style>
  .services-section {
    background: #0a0a0a;
    padding: 90px 0 80px;
    overflow: hidden;
  }

  /* ── Header ── */
  .services-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
    padding: 0 24px;
  }

  .section-label {
    font-family: "Syne", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #e05c2a;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: "Syne", sans-serif;
    font-size: clamp(28px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 15px;
    font-weight: 300;
    color: #777;
    line-height: 1.65;
  }

  /* ── Carousel ── */
  .carousel-outer {
    overflow: hidden;
    padding-left: clamp(24px, 6vw, 80px);
  }

  .carousel-track {
    display: flex;
    gap: 20px;
    will-change: transform;
    cursor: grab;
    user-select: none;
  }

  .carousel-track:active {
    cursor: grabbing;
  }

  /* ── Cards ── */
  .service-card {
    flex: 0 0 580px;
    background: #111111;
    border: 1px solid #1e1e1e;
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .service-card:hover {
    border-color: #2e2e2e;
    transform: translateY(-4px);
  }

  /* ── Image ── */
  .card-image {
    position: relative;
    width: 100%;
    height: 320px;
    background: #161616;
    overflow: hidden;
  }

  /* Placeholder visible por defecto (debajo de la img) */
  .card-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #333;
    border: 1px dashed #252525;
    margin: 16px;
    border-radius: 10px;
    z-index: 0;
  }

  /* La img flota encima. Empieza invisible; cuando carga, .loaded la muestra */
  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: transform 0.5s ease, opacity 0.4s ease;
    z-index: 1;
  }

  .card-img.loaded {
    opacity: 1;
  }

  .service-card:hover .card-img {
    transform: scale(1.04);
  }

  .card-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 64px;
    background: linear-gradient(to top, #111111, transparent);
    pointer-events: none;
    z-index: 2;
  }

  /* ── Body ── */
  .card-body {
    padding: 28px 28px 26px;
  }

  .card-number {
    font-family: "Syne", sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: #222222;
    line-height: 1;
    margin-bottom: 14px;
  }

  .card-title {
    font-family: "Syne", sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .card-desc {
    font-size: 14px;
    font-weight: 300;
    color: #888888;
    line-height: 1.7;
    margin-bottom: 22px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 11px;
    font-weight: 500;
    color: #666;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    padding: 5px 12px;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  /* ── Controls ── */
  .carousel-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding-left: clamp(24px, 6vw, 80px);
  }

  .nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #222;
    background: transparent;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease, background 0.2s ease;
    flex-shrink: 0;
  }

  .nav-btn:hover {
    border-color: #ff4d1c;
    background: #ff4d1c;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .service-card { flex: 0 0 460px; }
    .card-image   { height: 260px; }
  }

  @media (max-width: 768px) {
    .services-section { padding: 64px 0 60px; }
    .service-card { flex: 0 0 340px; }
    .card-image   { height: 210px; }
  }

  @media (max-width: 480px) {
    .service-card { flex: 0 0 280px; }
    .card-image   { height: 180px; }
  }
</style>

<script>
  // DOMContentLoaded garantiza que el DOM esté listo antes de buscar los elementos
  document.addEventListener("DOMContentLoaded", () => {
    const track   = document.getElementById("servicesTrack") as HTMLElement | null;
    const prevBtn = document.getElementById("prevBtn")       as HTMLButtonElement | null;
    const nextBtn = document.getElementById("nextBtn")       as HTMLButtonElement | null;

    if (!track || !prevBtn || !nextBtn) return;

    const GAP      = 20;
    const allCards = Array.from(track.querySelectorAll<HTMLElement>(".service-card"));
    const total    = allCards.length / 2; // la segunda mitad son clones

    let currentIndex  = 0;
    let isTransitioning = false;

    /* ── Imágenes: añade .loaded cuando cargan, silencia el error de consola ── */
    track.querySelectorAll<HTMLImageElement>(".card-img").forEach((img) => {
      // Si ya cargó (caché)
      if (img.complete && img.naturalWidth > 0) {
        img.classList.add("loaded");
      } else {
        img.addEventListener("load",  () => img.classList.add("loaded"));
        img.addEventListener("error", () => { /* no hacer nada; placeholder queda visible */ });
      }
    });

    /* ── Helpers ── */
    function getCardWidth(): number {
      return allCards[0].offsetWidth + GAP;
    }

    function setPosition(index: number, animate: boolean) {
      track.style.transition = animate
        ? "transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
        : "none";
      track.style.transform = `translateX(-${index * getCardWidth()}px)`;
    }

    function goNext() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex++;
      setPosition(currentIndex, true);
    }

    function goPrev() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex--;
      setPosition(currentIndex, true);
    }

    /* ── Loop infinito ──
       Cuando llega al clon del primer elemento (index === total)
       salta silenciosamente al original sin animación, y viceversa. */
    track.addEventListener("transitionend", () => {
      isTransitioning = false;

      if (currentIndex >= total) {
        currentIndex -= total;
        setPosition(currentIndex, false);
      } else if (currentIndex < 0) {
        currentIndex += total;
        setPosition(currentIndex, false);
      }
    });

    nextBtn.addEventListener("click", goNext);
    prevBtn.addEventListener("click", goPrev);

    /* ── Drag / Swipe ── */
    let startX   = 0;
    let dragging = false;

    track.addEventListener("mousedown",  (e) => { dragging = true; startX = e.clientX; });
    track.addEventListener("mouseup",    (e) => {
      if (!dragging) return;
      dragging = false;
      const diff = startX - e.clientX;
      if (Math.abs(diff) > 50) diff > 0 ? goNext() : goPrev();
    });
    track.addEventListener("mouseleave", () => { dragging = false; });

    track.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener("touchend",   (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? goNext() : goPrev();
    });

    /* ── Resize ── */
    window.addEventListener("resize", () => setPosition(currentIndex, false));
  });
</script>