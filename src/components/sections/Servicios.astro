---
const servicios = [
  {
    id: "startups",
    titulo: "Webs para Startups & Tech",
    descripcion:
      "Construimos sitios web rápidos, modernos y de alto impacto para Startups y empresas de tecnología.",
    imagenSrc: "/servicio-seo.png",
    imagenAlt: "Webs para Startups & Tech",
  },
  {
    id: "clinicas",
    titulo: "Sitios Clínicos (Odontología y Estética)",
    descripcion:
      "Diseñamos interfaces de primera clase que transmiten confianza médica, diseñadas para captar clientes mediante SEO Local y sistemas de agendamiento.",
    imagenSrc: "/servicios-ai.png",
    imagenAlt: "Sitios Clínicos (Odontología y Estética)",
  },
  {
    id: "ecommerce",
    titulo: "E-commerce de alto impacto",
    descripcion:
      "Tiendas online rápidas, con pasarelas integradas y automatizaciones de IA para recuperar carritos y disparar tus ventas.",
    imagenSrc: "/servicio-diseño.png",
    imagenAlt: "E-commerce de alto impacto",
  },
  {
    id: "ia",
    titulo: "IA & Automatizaciones",
    descripcion:
      "Conectamos tu ecosistema web con herramientas de Inteligencia Artificial para optimizar tus procesos internos.",
    imagenSrc: "/servicio-tech.png",
    imagenAlt: "IA & Automatizaciones",
  },
  {
    id: "seo",
    titulo: "SEO Y CRO",
    descripcion:
      "Estrategias avanzadas de SEO y CRO para que tu web no solo atraiga tráfico, sino que convierta visitantes en clientes de alto valor.",
    imagenSrc: "/servicios-ia.png",
    imagenAlt: "SEO Y CRO",
  },
];
---

<section id="servicios" class="srv-section">
  <div class="srv-inner">
    <!-- Header -->
    <div class="srv-header">
      <span class="section-label">Lo que hacemos</span>
      <h2 class="srv-title">Nuestros Servicios</h2>
    </div>

    <!-- Slider -->
    <div class="srv-slider">
      <!-- Image side -->
      <div class="srv-slider__visual">
        {
          servicios.map((s, i) => (
            <div
              class={`srv-slide-img${i === 0 ? " is-visible" : ""}`}
              data-slide-img={i}
            >
              <img
                src={s.imagenSrc}
                alt={s.imagenAlt}
                loading={i === 0 ? "eager" : "lazy"}
              />
            </div>
          ))
        }
        <!-- Slide counter -->
        <div class="srv-counter">
          <span class="srv-counter__current">01</span>
          <span class="srv-counter__sep">/</span>
          <span class="srv-counter__total">05</span>
        </div>
      </div>

      <!-- Content side -->
      <div class="srv-slider__content">
        {
          servicios.map((s, i) => (
            <div
              class={`srv-slide-content${i === 0 ? " is-visible" : ""}`}
              data-slide-content={i}
            >
              <h3 class="srv-slide__title">{s.titulo}</h3>
              <p class="srv-slide__desc">{s.descripcion}</p>
              <a
                href="https://cal.com/arkaagency/reunion-acercamiento"
                target="_blank"
                rel="noopener noreferrer"
                class="srv-slide__cta"
              >
                <span>Cotiza tu proyecto</span>
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </>
                </svg>
              </a>
            </div>
          ))
        }

        <!-- Navigation -->
        <div class="srv-nav">
          <button class="srv-nav__btn srv-nav__prev" aria-label="Anterior">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m15 18-6-6 6-6"></path>
            </svg>
          </button>

          <!-- Dots / Progress indicators -->
          <div class="srv-nav__dots">
            {
              servicios.map((s, i) => (
                <button
                  class={`srv-nav__dot${i === 0 ? " is-active" : ""}`}
                  data-dot={i}
                  aria-label={`Ir a ${s.titulo}`}
                >
                  <span class="srv-nav__dot-fill" />
                </button>
              ))
            }
          </div>

          <button class="srv-nav__btn srv-nav__next" aria-label="Siguiente">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector<HTMLElement>("#servicios");
  if (section) {
    const imgs = Array.from(
      section.querySelectorAll<HTMLElement>("[data-slide-img]"),
    );
    const contents = Array.from(
      section.querySelectorAll<HTMLElement>("[data-slide-content]"),
    );
    const dots = Array.from(
      section.querySelectorAll<HTMLElement>("[data-dot]"),
    );
    const prevBtn = section.querySelector<HTMLElement>(".srv-nav__prev");
    const nextBtn = section.querySelector<HTMLElement>(".srv-nav__next");
    const counterCurrent = section.querySelector<HTMLElement>(
      ".srv-counter__current",
    );

    let current = 0;

    function goTo(index: number) {
      if (index === current) return;

      imgs[current]?.classList.remove("is-visible");
      contents[current]?.classList.remove("is-visible");
      dots[current]?.classList.remove("is-active");

      current = index;

      imgs[current]?.classList.add("is-visible");
      contents[current]?.classList.add("is-visible");
      dots[current]?.classList.add("is-active");

      if (counterCurrent) {
        counterCurrent.textContent = String(current + 1).padStart(2, "0");
      }
    }

    function next() {
      goTo((current + 1) % imgs.length);
    }

    function prev() {
      goTo((current - 1 + imgs.length) % imgs.length);
    }

    nextBtn?.addEventListener("click", next);
    prevBtn?.addEventListener("click", prev);

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => goTo(i));
    });

    section.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") next();
      if (e.key === "ArrowLeft") prev();
    });

    let touchStartX = 0;
    const slider = section.querySelector<HTMLElement>(".srv-slider");
    slider?.addEventListener(
      "touchstart",
      (e) => {
        touchStartX = e.changedTouches[0].clientX;
      },
      { passive: true },
    );

    slider?.addEventListener(
      "touchend",
      (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          diff > 0 ? next() : prev();
        }
      },
      { passive: true },
    );
  }
</script>
