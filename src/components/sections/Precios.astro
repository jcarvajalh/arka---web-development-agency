---
---

<section id="precios" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-gray-900 text-center mb-12">Nuestros Planes</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Plan Básico -->
      <div class="bg-white p-8 rounded-lg border border-gray-200 hover:shadow-lg transition">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">Plan Básico</h3>
        <p class="text-gray-600 mb-6">Perfecto para startups</p>
        
        <div class="mb-6">
          <span class="text-5xl font-bold text-gray-900">$299</span>
          <span class="text-gray-600">/mes</span>
        </div>

        <ul class="space-y-4 mb-8 text-gray-700">
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Sitio web responsivo
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Hasta 5 páginas
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Certificado SSL
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Soporte por email
          </li>
        </ul>

        <button class="w-full bg-gray-200 text-gray-900 py-3 rounded-lg font-semibold hover:bg-gray-300 transition">
          Seleccionar Plan
        </button>
      </div>

      <!-- Plan Profesional -->
      <div class="bg-white p-8 rounded-lg border-2 border-blue-600 hover:shadow-lg transition relative">
        <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
          <span class="bg-blue-600 text-white px-4 py-1 rounded-full text-sm font-semibold">Popular</span>
        </div>

        <h3 class="text-2xl font-bold text-gray-900 mb-2 mt-6">Plan Profesional</h3>
        <p class="text-gray-600 mb-6">Para empresas en crecimiento</p>
        
        <div class="mb-6">
          <span class="text-5xl font-bold text-gray-900">$799</span>
          <span class="text-gray-600">/mes</span>
        </div>

        <ul class="space-y-4 mb-8 text-gray-700">
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Sitio web avanzado
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Hasta 20 páginas
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            SEO optimizado
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Soporte prioritario
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Actualizaciones mensuales
          </li>
        </ul>

        <button class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
          Seleccionar Plan
        </button>
      </div>

      <!-- Plan Enterprise -->
      <div class="bg-white p-8 rounded-lg border border-gray-200 hover:shadow-lg transition">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">Plan Enterprise</h3>
        <p class="text-gray-600 mb-6">Solución personalizada</p>
        
        <div class="mb-6">
          <span class="text-5xl font-bold text-gray-900">Personalizado</span>
        </div>

        <ul class="space-y-4 mb-8 text-gray-700">
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Solución a medida
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            E-commerce integrado
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Integraciones personalizadas
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Soporte 24/7
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-3">✓</span>
            Mantenimiento incluido
          </li>
        </ul>

        <button class="w-full border-2 border-blue-600 text-blue-600 py-3 rounded-lg font-semibold hover:bg-blue-50 transition">
          Solicitar Propuesta
        </button>
      </div>
    </div>
  </div>
</section>
