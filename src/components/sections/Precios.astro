---
// Precios.astro — Sección de paquetes con toggle COP/USD
---

<section id="precios" class="precios-section pb-20">
    <!-- Header — mismo patrón que Proceso -->
    <div class="precios-header text-center mx-auto mb-14 px-6">
        <p class="section-label">Precios</p>
        <h2 class="precios-title">Elige el punto de partida</h2>
        <p class="precios-sub">
            Cada paquete se adapta a tu marca. Te decimos exactamente qué
            incluye; el alcance final lo definimos juntos en una reunión.
        </p>

        <!-- Currency Toggle -->
        <div class="currency-toggle" id="currencyToggle">
            <button class="currency-toggle__btn is-active" data-currency="cop">
                <span class="currency-toggle__flag">🇨🇴</span>
                <span>COP</span>
            </button>
            <button class="currency-toggle__btn" data-currency="usd">
                <span class="currency-toggle__flag">🇺🇸</span>
                <span>USD</span>
            </button>
            <span class="currency-toggle__slider"></span>
        </div>
    </div>

    <!-- Grid de tarjetas — mismo ancho que proceso-grid -->
    <div class="precios-grid mx-auto">
        <!-- Sitios Web -->
        <article class="paquete-card">
            <span class="paquete-tag">DESARROLLO WEB</span>

            <h3 class="paquete-titulo">
                Sitios Web<br />&amp; E-commerce
            </h3>

            <p class="paquete-desc">
                Diseñamos y desarrollamos landing pages, sitios web y tiendas
                online optimizadas para posicionar tu marca, atraer clientes y
                aumentar las conversiones.
            </p>

            <p class="paquete-precio">
                <span data-price-cop>
                    Desde <strong>COP 2.500.000</strong>
                </span>
                <span data-price-usd class="hidden">
                    Desde <strong>USD 625</strong>
                </span>
            </p>

            <a
                href="https://cal.com/arkaagency/reunion-acercamiento"
                target="_blank"
                rel="noopener noreferrer"
                class="paquete-btn paquete-btn--outline py-3.5 mb-7 relative flex items-center justify-center"
            >
                <span>Cotiza tu proyecto</span>
            </a>

            <ul class="paquete-features mb-5">
                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Landing pages, sitios corporativos y e-commerce</strong
                        >
                        desarrollados completamente a medida.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >SEO técnico y arquitectura orientada a CRO</strong
                        >
                        para atraer tráfico y convertir visitantes en clientes.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong>Astro o Next.js</strong> para obtener máxima velocidad,
                        rendimiento y escalabilidad.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Google Analytics 4, Tag Manager y Microsoft Clarity</strong
                        >
                        configurados desde el lanzamiento.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Copywriting estratégico, UX y microinteracciones</strong
                        >
                        diseñadas para aumentar la conversión.
                    </span>
                </li>
            </ul>

            <p class="paquete-footer">
                Ideal para empresas Tech, SaaS, clínicas y negocios que buscan
                generar más clientes, ventas y oportunidades desde su sitio web.
            </p>
        </article>

        <!-- Aplicaciones Web -->
        <article class="paquete-card paquete-card--featured">
            <span class="paquete-tag paquete-tag--accent">
                DESARROLLO DE SOFTWARE
            </span>

            <h3 class="paquete-titulo">
                Aplicaciones<br />Web a Medida
            </h3>

            <p class="paquete-desc">
                Desarrollamos aplicaciones web, plataformas empresariales y
                software personalizado para automatizar procesos, integrar
                sistemas y escalar el crecimiento de tu empresa.
            </p>

            <p class="paquete-precio">
                <span data-price-cop>
                    <strong>Precio según alcance</strong>
                </span>

                <span data-price-usd class="hidden">
                    <strong>Custom Pricing</strong>
                </span>

                <span>Cotización personalizada</span>
            </p>

            <a
                href="https://cal.com/arkaagency/reunion-acercamiento"
                target="_blank"
                rel="noopener noreferrer"
                class="paquete-btn paquete-btn--solid py-3.5 mb-7 relative flex items-center justify-center"
            >
                <span>Agenda una reunión</span>
            </a>

            <ul class="paquete-features mb-5">
                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong>Levantamiento de requerimientos</strong> y análisis
                        de procesos para definir la mejor solución.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Aplicaciones web, portales y sistemas empresariales</strong
                        >
                        desarrollados completamente a medida.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Integración con APIs, CRM, ERP y plataformas
                            externas</strong
                        >
                        para centralizar la información.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Dashboards, paneles administrativos y
                            automatizaciones</strong
                        >
                        adaptados a tus procesos.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong
                            >Arquitectura escalable, mantenimiento y soporte
                            evolutivo</strong
                        >
                        para acompañar el crecimiento de tu empresa.
                    </span>
                </li>

                <li>
                    <span class="paquete-check"></span>
                    <span>
                        <strong>Integración con Inteligencia Artificial</strong>
                        para automatizar tareas y optimizar procesos de negocio.
                    </span>
                </li>
            </ul>

            <p class="paquete-footer">
                Ideal para empresas que necesitan un software personalizado para
                agilizar procesos y mejorar su productividad.
            </p>
        </article>
    </div>
</section>

<script>
    // ── Currency Toggle + Geolocation ──
    const toggle = document.getElementById("currencyToggle");
    const copBtns = toggle?.querySelectorAll<HTMLElement>("[data-currency]");
    const copPrices =
        document.querySelectorAll<HTMLElement>("[data-price-cop]");
    const usdPrices =
        document.querySelectorAll<HTMLElement>("[data-price-usd]");
    const slider = toggle?.querySelector<HTMLElement>(
        ".currency-toggle__slider",
    );

    function setCurrency(currency: "cop" | "usd") {
        const isCop = currency === "cop";

        copPrices.forEach((el) => el.classList.toggle("hidden", !isCop));
        usdPrices.forEach((el) => el.classList.toggle("hidden", isCop));

        copBtns?.forEach((btn) => {
            const btnCurrency = btn.getAttribute("data-currency");
            btn.classList.toggle("is-active", btnCurrency === currency);
        });

        // Move slider indicator
        if (slider) {
            slider.style.transform = isCop
                ? "translateX(0)"
                : "translateX(100%)";
        }

        // Save preference
        localStorage.setItem("arka-currency", currency);
    }

    // Button clicks
    copBtns?.forEach((btn) => {
        btn.addEventListener("click", () => {
            const currency = btn.getAttribute("data-currency") as "cop" | "usd";
            setCurrency(currency);
        });
    });

    // Initialize: check saved preference first, then geolocation
    const saved = localStorage.getItem("arka-currency") as "cop" | "usd" | null;

    if (saved) {
        setCurrency(saved);
    } else {
        // Auto-detect with free geolocation API (no key needed)
        fetch("https://ipapi.co/json/", { signal: AbortSignal.timeout(3000) })
            .then((res) => res.json())
            .then((data) => {
                const country = data?.country_code?.toUpperCase();
                setCurrency(country === "CO" ? "cop" : "usd");
            })
            .catch(() => {
                // Fallback: default to COP
                setCurrency("cop");
            });
    }
</script>
